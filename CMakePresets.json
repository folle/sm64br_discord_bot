{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 27,
    "patch": 2
  },
  "configurePresets": [
    {
      "name": "default",
      "description": "Common settings between Windows and Linux builds.",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/${presetName}",
      "toolchainFile": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake"
    },
    {
      "name": "windows-base",
      "description": "Target Windows with the Visual Studio development environment.",
      "inherits": "default",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl.exe",
        "CMAKE_CXX_COMPILER": "cl.exe"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-x64-debug",
      "displayName": "Windows x64 Debug",
      "description": "Target Windows (64-bit) with the Visual Studio development environment. (Debug)",
      "inherits": "windows-base",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-x64-release",
      "displayName": "Windows x64 Release",
      "description": "Target Windows (64-bit) with the Visual Studio development environment. (Release)",
      "inherits": "windows-base",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-base",
      "description": "Target Linux with the gcc/g++ development environment.",
      "inherits": "default",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "environment": {
        "VCPKG_FORCE_SYSTEM_BINARIES": "1"
      }
    },
    {
      "name": "linux-aarch64-debug",
      "displayName": "Linux AArch64 Debug",
      "description": "Target Linux (AArch64) with the gcc/g++ development environment. (Debug)",
      "inherits": "linux-base",
      "architecture": {
        "value": "ARM64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-aarch64-release",
      "displayName": "Linux AArch64 Release",
      "description": "Target Linux (AArch64) with the gcc/g++ development environment. (Release)",
      "inherits": "linux-base",
      "architecture": {
        "value": "ARM64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-x64-debug",
      "displayName": "Windows x64-Debug",
      "description": "Debug build for Windows x64",
      "configurePreset": "windows-x64-debug"
    },
    {
      "name": "windows-x64-release",
      "displayName": "Windows x64-Release",
      "description": "Release build for Windows x64",
      "configurePreset": "windows-x64-release"
    },
    {
      "name": "linux-aarch64-debug",
      "displayName": "Linux AArch64-Debug",
      "description": "Debug build for Linux AArch64",
      "configurePreset": "linux-aarch64-debug"
    },
    {
      "name": "linux-aarch64-release",
      "displayName": "Linux AArch64-Release",
      "description": "Release build for Linux AArch64",
      "configurePreset": "linux-aarch64-release"
    }
  ]
}